resource "compute-type-set" "kubernetes-ubuntu-20-04-ha-worker-xen-amd64-set" {
  code = "kubernetes-ubuntu-20-04-ha-worker-xen-amd64-set"
  name = "kubernetes worker"
  category = "ubuntu"
  canAddNodes = true
  computeServerType = { code = "xenKubeWorker" }
  dynamicCount = true
  nameSuffix = "-worker"
  nodeCount = 3
  nodeType = "worker"
  priorityOrder = 2
  workloadType = { code = "kubernetes-ubuntu-20-04-worker-xen-amd64" }
}